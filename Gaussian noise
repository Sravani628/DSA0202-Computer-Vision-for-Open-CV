import cv2
import numpy as np

img = cv2.imread(r"C:\Users\srava\OneDrive\Desktop\Pictures\tree.jpg.png")

if img is None:
    print("Error: Image not found")
else:
    noise = np.random.normal(0, 25, img.shape)
    gaussian = img + noise
    gaussian = np.clip(gaussian, 0, 255).astype(np.uint8)

    cv2.imshow("Original Image", img)
    cv2.imshow("Gaussian Noise", gaussian)

    cv2.waitKey(0)
    cv2.destroyAllWindows()
